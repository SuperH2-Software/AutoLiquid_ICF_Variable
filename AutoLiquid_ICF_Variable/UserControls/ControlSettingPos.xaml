<UserControl x:Class="AutoLiquid_ICF_Variable.UserControls.ControlSettingPos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" >

    <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
            <Button Name="BtnMinus" ToolTip="{StaticResource Minus}" Margin="0" Width="{StaticResource BtnTrimmingWidth}">
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Image Name="img" Source="/AutoLiquid_Library;component/Images/minus_default.png"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="img" Property="Source" Value="/AutoLiquid_Library;component/Images/minus_mouseover.png"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="img" Property="Source" Value="/AutoLiquid_Library;component/Images/minus_mouseclick.png"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBox x:Name="TextBoxPos" Width="{StaticResource SettingValueWidth}" HorizontalContentAlignment="Center" Text="0" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
            <Button Name="BtnAdd" ToolTip="{StaticResource Add}" Margin="0" Width="{StaticResource BtnTrimmingWidth}">
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Image Name="img" Source="/AutoLiquid_Library;component/Images/add_default.png"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="img" Property="Source" Value="/AutoLiquid_Library;component/Images/add_mouseover.png"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="img" Property="Source" Value="/AutoLiquid_Library;component/Images/add_mouseclick.png"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Label x:Name="LabelUnit" Content="mm" HorizontalContentAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="-5,0,0,0" VerticalAlignment="Center"/>
            <Button x:Name="BtnExecute" Content="{StaticResource Execute}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="60" Height="30" FontSize="{StaticResource SettingBtnFontSize}"/>
        </StackPanel>
    </Grid>
</UserControl>
