<UserControl x:Class="AutoLiquid_ICF_Variable.UserControls.ControlSettingHeadAttribute"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Background="White">
    <UserControl.Resources>
    </UserControl.Resources>

    <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,5,0,0">
                <StackPanel Orientation="Horizontal">
                    <Label HorizontalContentAlignment="Center" Content="{StaticResource ChannelCount}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <ComboBox x:Name="ComboBoxChannelRow" Width="{StaticResource SettingValueWidth}" HorizontalContentAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.Default}" SelectedIndex="0">
                        <system:Int32>1</system:Int32>
                        <system:Int32>2</system:Int32>
                        <system:Int32>3</system:Int32>
                        <system:Int32>4</system:Int32>
                        <system:Int32>5</system:Int32>
                        <system:Int32>6</system:Int32>
                        <system:Int32>7</system:Int32>
                        <system:Int32>8</system:Int32>
                        <system:Int32>9</system:Int32>
                        <system:Int32>10</system:Int32>
                        <system:Int32>11</system:Int32>
                        <system:Int32>12</system:Int32>
                    </ComboBox>
                    <Label Content="{StaticResource Row}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <ComboBox x:Name="ComboBoxChannelCol" Width="{StaticResource SettingValueWidth}" HorizontalContentAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.Default}" SelectedIndex="0" Margin="5,0,0,0">
                        <system:Int32>1</system:Int32>
                        <system:Int32>2</system:Int32>
                        <system:Int32>3</system:Int32>
                        <system:Int32>4</system:Int32>
                        <system:Int32>5</system:Int32>
                        <system:Int32>6</system:Int32>
                        <system:Int32>7</system:Int32>
                        <system:Int32>8</system:Int32>
                        <system:Int32>9</system:Int32>
                        <system:Int32>10</system:Int32>
                        <system:Int32>11</system:Int32>
                        <system:Int32>12</system:Int32>
                    </ComboBox>
                    <Label Content="{StaticResource Col}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                </StackPanel>

                <StackPanel x:Name="StackPanelChannelStep" Orientation="Horizontal" Margin="10,0,0,0">
                    <Label HorizontalContentAlignment="Center" Content="{StaticResource ChannelStep}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <ComboBox x:Name="ComboBoxChannelStep" Width="{StaticResource SettingValueWidth}" HorizontalContentAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.Default}" SelectedIndex="0" >
                        <system:Decimal>9.0</system:Decimal>
                        <system:Decimal>18.0</system:Decimal>
                    </ComboBox>
                    <Label Content="mm" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                    <Label HorizontalContentAlignment="Center" Content="{StaticResource LiquidRange}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <ComboBox x:Name="ComboBoxLiquidRange" Width="{StaticResource SettingValueWidth}" HorizontalContentAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.Default}" SelectedIndex="0">
                        <ComboBoxItem Content="10" Tag="10"/>
                        <ComboBoxItem Content="12.5" Tag="12"/>
                        <ComboBoxItem Content="20" Tag="20"/>
                        <ComboBoxItem Content="50" Tag="50"/>
                        <ComboBoxItem Content="110" Tag="110"/>
                        <ComboBoxItem Content="200" Tag="200"/>
                        <ComboBoxItem Content="300" Tag="300"/>
                        <ComboBoxItem Content="1000" Tag="1000"/>
                        <ComboBoxItem Content="1200" Tag="1200"/>
                        <ComboBoxItem Content="5000" Tag="5000"/>
                    </ComboBox>
                    <Label Content="μl" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                </StackPanel>

                <StackPanel x:Name="StackPanelVariable" Orientation="Horizontal" Margin="10,0,0,0">
                    <Label HorizontalContentAlignment="Center" Content="{StaticResource VariableDistance}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <RadioButton x:Name="RBtnVariableNo" GroupName="Variable" Content="{StaticResource No}"  FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center" IsChecked="True"/>
                    <RadioButton x:Name="RBtnVariableYes" GroupName="Variable" Content="{StaticResource Yes}" FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                    <Label HorizontalContentAlignment="Center" Content="{StaticResource WalkingLogic}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <RadioButton x:Name="RBtnWalkingLogicSameTime" GroupName="WalkingLogic" Content="{StaticResource SameTime}"  FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center" IsChecked="True"/>
                    <RadioButton x:Name="RBtnWalkingLogicXFirst" GroupName="WalkingLogic" Content="{StaticResource XFirst}" FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <RadioButton x:Name="RBtnWalkingLogicYFirst" GroupName="WalkingLogic" Content="{StaticResource YFirst}" FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
