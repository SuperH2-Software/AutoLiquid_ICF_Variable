<UserControl x:Class="AutoLiquid_ICF_Variable.UserControls.ControlSettingReleaseTip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Background="White">
    <UserControl.Resources>
        <Thickness x:Key="RowMarginTop">0,5,0,0</Thickness>
        <Thickness x:Key="RowMarginLeftAndTop">15,5,0,0</Thickness>
    </UserControl.Resources>

    <Grid>
        <StackPanel Orientation="Vertical" Margin="0,5,0,0">
            <!--退枪头方式-->
            <StackPanel Orientation="Horizontal">
                <StackPanel x:Name="StackPanelReleaseTipMethod" Orientation="Horizontal">
                    <Label HorizontalContentAlignment="Center" Content="{StaticResource ReleaseTipMethod}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <RadioButton x:Name="RBtnReleaseTipMethodPush" GroupName="ReleaseTipMethod" Content="{StaticResource PlatePush}" FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center" IsChecked="True"/>
                    <RadioButton x:Name="RBtnReleaseTipMethodHook" GroupName="ReleaseTipMethod" Content="{StaticResource Hook}" FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel x:Name="StackPanelReleaseTipPush" Orientation="Horizontal">
                    <!--退枪头轴-->
                    <StackPanel x:Name="StackPanelReleaseTipAxis" Orientation="Horizontal">
                        <Label Width="{StaticResource SettingTitleWidth}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="{StaticResource ReleaseTipAxis}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                        <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                        <RadioButton x:Name="RBtnReleaseTipAxisP" GroupName="ReleaseTipAxis" Content="P" FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center" IsChecked="True"/>
                        <RadioButton x:Name="RBtnReleaseTipAxisQ" GroupName="ReleaseTipAxis" Content="Q" FontSize="{StaticResource MahApps.Font.Size.Default}" VerticalAlignment="Center"  Margin="10,0,0,0"/>
                    </StackPanel>

                    <!--推脱板次数-->
                    <StackPanel Orientation="Horizontal">
                        <Label HorizontalContentAlignment="Center" Content="{StaticResource PlatePushCount}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                        <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                        <ComboBox x:Name="ComboBoxPushCount" Width="{StaticResource SettingValueWidth}" HorizontalContentAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.Default}" SelectedIndex="0">
                            <system:Int32>1</system:Int32>
                            <system:Int32>2</system:Int32>
                            <system:Int32>3</system:Int32>
                        </ComboBox>
                    </StackPanel>

                    <!--推脱板偏移-->
                    <StackPanel x:Name="StackPanelReleaseTipOffset" Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{StaticResource Prompt_Set_Negative}">
                        <Label Width="{StaticResource SettingTitleWidth}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="{StaticResource ReleaseTipOffset}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                        <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                        <local:ControlSettingPos x:Name="ControlReleaseTipOffset"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Separator Margin="5" Background="LightGray">
                <Separator.RenderTransform>
                    <ScaleTransform ScaleY="2" />
                </Separator.RenderTransform>
            </Separator>

            <!--退枪头位置1、2、3、4-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <local:ControlSettingReleaseTipPos Grid.Row="0" Grid.Column="0" x:Name="ControlSettingReleaseTipPos1"/>
                <local:ControlSettingReleaseTipPos Grid.Row="0" Grid.Column="1" x:Name="ControlSettingReleaseTipPos2" Margin="20,0,0,0"/>
                <local:ControlSettingReleaseTipPos Grid.Row="1" Grid.Column="0" x:Name="ControlSettingReleaseTipPos3" Margin="0,10,0,0"/>
                <local:ControlSettingReleaseTipPos Grid.Row="1" Grid.Column="1" x:Name="ControlSettingReleaseTipPos4" Margin="20,10,0,0"/>
            </Grid>

            <Separator Margin="5" Background="LightGray">
                <Separator.RenderTransform>
                    <ScaleTransform ScaleY="2" />
                </Separator.RenderTransform>
            </Separator>

            <StackPanel Orientation="Horizontal"  Margin="25,0,0,0">
                <!--预退枪头是否先走X轴-->
                <CheckBox x:Name="CheckBoxAxisXGoFirst" Content="{StaticResource AxisXGoFirst}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                <!--预退枪头是否先走Y轴-->
                <CheckBox x:Name="CheckBoxAxisYGoFirst" Content="{StaticResource AxisYGoFirst}" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="10,0,0,0"/>
                <!--是否返回取枪头位置退枪头-->
                <CheckBox x:Name="CheckBoxReleaseTipBack2TakePos" Content="{StaticResource ReleaseTipBack2TakePos}" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="25,0,0,0"/>
                <!--是否退枪头前高度回零-->
                <CheckBox x:Name="CheckBoxReleaseTipZa0Before" Content="{StaticResource ReleaseTipZa0Before}" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="25,0,0,0"/>
                <!--是否退枪头后高度回零-->
                <CheckBox x:Name="CheckBoxReleaseTipZa0After" Content="{StaticResource ReleaseTipZa0After}" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="25,0,0,0"/>
                <!--退枪头速度-->
                <StackPanel x:Name="StackPanelReleaseTipSpeedCmd" Orientation="Horizontal">
                    <Label Width="{StaticResource SettingTitleWidth}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="{StaticResource ReleaseTipSpeedCmd}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <TextBox x:Name="TextBoxReleaseTipSpeedCmd" Width="{StaticResource SettingSpeedWidth}" HorizontalContentAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.Default}" />
                </StackPanel>
                <!--退枪头后指令-->
                <StackPanel x:Name="StackPanelReleaseTipAfterCmd" Orientation="Horizontal">
                    <Label Width="{StaticResource SettingTitleWidth}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Content="{StaticResource ReleaseTipAfterCmd}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                    <TextBox x:Name="TextBoxReleaseTipAfterCmd" Width="{StaticResource SettingSpeedWidth}" HorizontalContentAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.Default}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
