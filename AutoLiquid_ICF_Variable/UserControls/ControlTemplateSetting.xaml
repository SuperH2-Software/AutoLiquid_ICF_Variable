<UserControl x:Class="AutoLiquid_ICF_Variable.UserControls.ControlTemplateSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             Background="White">
    <UserControl.Resources>
        <system:Double x:Key="TitleWidth">85</system:Double>
    </UserControl.Resources>

    <Grid x:Name="GridTemplate" Margin="10,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0" Width="{StaticResource TitleWidth}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <CheckBox x:Name="CheckBoxTemplate" HorizontalAlignment="Center" Padding="0"/>
                <Label x:Name="LabelTemplateName" HorizontalContentAlignment="Center" Content="{StaticResource Template}" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
            <Label Width="{StaticResource BtnTrimmingWidth}"/>
            <Label Width="{StaticResource SettingHoleValueWidth}" HorizontalContentAlignment="Center" Content="{StaticResource ValueX}" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold" HorizontalAlignment="Left"/>
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal">
            <Label Width="{StaticResource BtnTrimmingWidth}"/>
            <Label Width="{StaticResource SettingHoleValueWidth}" HorizontalContentAlignment="Center" Content="{StaticResource ValueY}" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold" HorizontalAlignment="Left"/>
        </StackPanel>
        <Label Grid.Row="1" Grid.Column="0" HorizontalContentAlignment="Center" Content="{StaticResource Hole1}" Width="{StaticResource TitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
        <Label Grid.Row="1" Grid.Column="1" Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
        <local:ControlSettingPos Grid.Row="1" Grid.Column="2" x:Name="ControlTemplateHole1X"/>
        <Label Grid.Row="1" Grid.Column="3" HorizontalContentAlignment="Center" Content="," Width="{StaticResource SettingColonWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
        <local:ControlSettingPos Grid.Row="1" Grid.Column="4" x:Name="ControlTemplateHole1Y"/>
    </Grid>
</UserControl>
