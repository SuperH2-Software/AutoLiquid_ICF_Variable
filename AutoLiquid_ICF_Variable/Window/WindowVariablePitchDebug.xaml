<metro:MetroWindow x:Class="AutoLiquid_ICF_Variable.Window.WindowVariablePitchDebug"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:metro="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="{StaticResource VariablePitchDebug}"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Closing="Window_Closing">

    <Grid Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══ 连接设置 ═══ -->
                    <GroupBox BorderThickness="{StaticResource GroupBoxBorderThickness}">
                        <GroupBox.Header>
                            <Label Content="连接设置"
                          FontSize="{StaticResource SettingGroupBoxTitleFontSize}"
                          Foreground="White"/>
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal" Margin="5,8">
                            <Label Content="CAN 设备 ID："
                          FontSize="{StaticResource SettingNormalFontSize}"
                          VerticalContentAlignment="Center"/>
                            <TextBox x:Name="TxtDeviceId"
                            Text="1"
                            Width="50" Height="30"
                            FontSize="{StaticResource SettingNormalFontSize}"
                            VerticalContentAlignment="Center"
                            Margin="0,0,10,0"/>
                            <CheckBox x:Name="ChkSimulate"
                             Content="模拟模式"
                             FontSize="{StaticResource SettingNormalFontSize}"
                             VerticalContentAlignment="Center"
                             Margin="0,0,15,0"/>
                            <Button x:Name="BtnConnect"
                           Content="连  接"
                           Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                           Height="30" Width="80"
                           FontSize="{StaticResource SettingBtnFontSize}"
                           Margin="5,0"
                           Click="BtnConnect_Click"/>
                            <Button x:Name="BtnDisconnect"
                           Content="断  开"
                           Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                           Height="30" Width="80"
                           FontSize="{StaticResource SettingBtnFontSize}"
                           Margin="5,0"
                           IsEnabled="False"
                           Click="BtnDisconnect_Click"/>
                            <Ellipse x:Name="EllipseStatus"
                            Width="16" Height="16"
                            Fill="Gray"
                            Margin="15,0,5,0"
                            VerticalAlignment="Center"/>
                            <Label x:Name="LblConnStatus"
                          Content="未连接"
                          FontSize="{StaticResource SettingNormalFontSize}"
                          Foreground="Gray"
                          VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ═══ 设备管理 ═══ -->
                    <GroupBox Grid.Column="1" BorderThickness="{StaticResource GroupBoxBorderThickness}" Margin="5,0,0,0">
                        <GroupBox.Header>
                            <Label Content="设备管理"
                                FontSize="{StaticResource SettingGroupBoxTitleFontSize}"
                                Foreground="White"/>
                        </GroupBox.Header>
                        <StackPanel Margin="5,8">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="新 ID (1~255)："
                                    FontSize="{StaticResource SettingNormalFontSize}"
                                    Width="{StaticResource SettingTitleWidth}"
                                    VerticalContentAlignment="Center"/>
                                <Label Content="："
                                    FontSize="{StaticResource SettingNormalFontSize}"
                                    Width="{StaticResource SettingColonWidth}"
                                    VerticalContentAlignment="Center"/>
                                <TextBox x:Name="TxtNewId"
                                      Text="1"
                                      Width="60" Height="30"
                                      FontSize="{StaticResource SettingNormalFontSize}"
                                      VerticalContentAlignment="Center"
                                      Margin="0,0,10,0"/>
                                <Button Content="修改 ID"
                                     Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                     Height="30" Width="80"
                                     FontSize="{StaticResource SettingBtnFontSize}"
                                     Margin="10,0,5,0"
                                     Click="BtnModifyId_Click"/>
                                <Button Content="查询 ID"
                                     Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                     Height="30" Width="80"
                                     FontSize="{StaticResource SettingBtnFontSize}"
                                     Margin="5,0"
                                     Click="BtnQueryId_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>



                <!-- ═══ 实时状态 ═══ -->
                <GroupBox BorderThickness="{StaticResource GroupBoxBorderThickness}" Margin="0,5,0,0">
                    <GroupBox.Header>
                        <Label Content="实时状态"
                               FontSize="{StaticResource SettingGroupBoxTitleFontSize}"
                               Foreground="White"/>
                    </GroupBox.Header>
                    <Grid Margin="5,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 状态指示灯组 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                            <Ellipse x:Name="EllReleasingTip" Width="14" Height="14" Fill="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Label Content="松开枪头" FontSize="{StaticResource SettingNormalFontSize}" VerticalContentAlignment="Center" Padding="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0">
                            <Ellipse x:Name="EllAtOrigin" Width="14" Height="14" Fill="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Label Content="14MM原点" FontSize="{StaticResource SettingNormalFontSize}" VerticalContentAlignment="Center" Padding="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                            <Ellipse x:Name="EllAspirating" Width="14" Height="14" Fill="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Label Content="吸液中" FontSize="{StaticResource SettingNormalFontSize}" VerticalContentAlignment="Center" Padding="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,20,0">
                            <Ellipse x:Name="EllDispensing" Width="14" Height="14" Fill="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Label Content="排液中" FontSize="{StaticResource SettingNormalFontSize}" VerticalContentAlignment="Center" Padding="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,0,20,0">
                            <Ellipse x:Name="EllPistonHoming" Width="14" Height="14" Fill="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Label Content="活塞自检" FontSize="{StaticResource SettingNormalFontSize}" VerticalContentAlignment="Center" Padding="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="0,0,20,0">
                            <Ellipse x:Name="EllCalibrating" Width="14" Height="14" Fill="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Label Content="校准中" FontSize="{StaticResource SettingNormalFontSize}" VerticalContentAlignment="Center" Padding="0"/>
                        </StackPanel>

                        <!-- 当前液量 + 刷新 -->
                        <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Label Content="当前液量："
                                   FontSize="{StaticResource SettingNormalFontSize}"
                                   VerticalContentAlignment="Center" Padding="0"/>
                            <Label x:Name="LblCurrentVolume"
                                   Content="—— µL"
                                   FontSize="{StaticResource SettingNormalFontSize}"
                                   Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                   FontWeight="Bold"
                                   VerticalContentAlignment="Center"
                                   Width="90" Padding="0"/>
                            <Button Content="刷  新"
                                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                    Height="30" Width="70"
                                    FontSize="{StaticResource SettingBtnFontSize}"
                                    Margin="10,0,5,0"
                                    Click="BtnRefreshStatus_Click"/>
                            <metro:ToggleSwitch x:Name="TglAutoRefresh"
                                               OnContent="自动刷新 开"
                                               OffContent="自动刷新 关"
                                               FontSize="{StaticResource SettingNormalFontSize}"
                                               VerticalAlignment="Center"
                                               Margin="5,0"
                                               IsOn="False"
                                               Toggled="TglAutoRefresh_Toggled"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ═══ 操作区（左右两列） ═══ -->
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── 左列 ── -->
                    <StackPanel Grid.Column="0" Margin="0,0,3,0">

                        <!-- 基础操作 -->
                        <GroupBox BorderThickness="{StaticResource GroupBoxBorderThickness}">
                            <GroupBox.Header>
                                <Label Content="基础操作"
                                       FontSize="{StaticResource SettingGroupBoxTitleFontSize}"
                                       Foreground="White"/>
                            </GroupBox.Header>
                            <WrapPanel Margin="5,8" Orientation="Horizontal">
                                <Button Content="松开枪头"
                                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                        Height="30" Width="90"
                                        FontSize="{StaticResource SettingBtnFontSize}"
                                        Margin="5,3"
                                        Click="BtnReleaseTip_Click"/>
                                <Button Content="活塞回零"
                                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                        Height="30" Width="90"
                                        FontSize="{StaticResource SettingBtnFontSize}"
                                        Margin="5,3"
                                        Click="BtnPistonHome_Click"/>
                                <Button Content="读取状态"
                                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                        Height="30" Width="90"
                                        FontSize="{StaticResource SettingBtnFontSize}"
                                        Margin="5,3"
                                        Click="BtnReadStatus_Click"/>
                                <Button Content="读取液量"
                                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                        Height="30" Width="90"
                                        FontSize="{StaticResource SettingBtnFontSize}"
                                        Margin="5,3"
                                        Click="BtnReadVolume_Click"/>
                            </WrapPanel>
                        </GroupBox>

                        <!-- 变距控制 -->
                        <GroupBox BorderThickness="{StaticResource GroupBoxBorderThickness}" Margin="0,5,0,0">
                            <GroupBox.Header>
                                <Label Content="变距控制"
                                       FontSize="{StaticResource SettingGroupBoxTitleFontSize}"
                                       Foreground="White"/>
                            </GroupBox.Header>
                            <StackPanel Margin="5,8">
                                <!-- 整数变距 -->
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Label Content="整数变距 (mm)："
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingTitleWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <Label Content="："
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingColonWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <ComboBox x:Name="CmbPitch1mm"
                                              Width="60" Height="30"
                                              FontSize="{StaticResource SettingNormalFontSize}"
                                              VerticalContentAlignment="Center"
                                              Margin="0,0,10,0">
                                        <ComboBoxItem Content=" 9"/>
                                        <ComboBoxItem Content="10"/>
                                        <ComboBoxItem Content="11"/>
                                        <ComboBoxItem Content="12"/>
                                        <ComboBoxItem Content="13"/>
                                        <ComboBoxItem Content="14" IsSelected="True"/>
                                    </ComboBox>
                                    <Label Content="mm"
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingUnitWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <Button Content="执 行"
                                            Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                            Height="30" Width="60"
                                            FontSize="{StaticResource SettingBtnFontSize}"
                                            Margin="10,0,0,0"
                                            Click="BtnSetPitch1mm_Click"/>
                                </StackPanel>

                                <!-- 0.5mm步进变距 -->
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Label Content="步进变距 (mm)："
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingTitleWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <Label Content="："
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingColonWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <TextBox x:Name="TxtPitchHalf"
                                             Text="9.5"
                                             Width="60" Height="30"
                                             FontSize="{StaticResource SettingNormalFontSize}"
                                             VerticalContentAlignment="Center"
                                             Margin="0,0,10,0"/>
                                    <Label Content="mm"
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingUnitWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <Button Content="执 行"
                                            Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                            Height="30" Width="60"
                                            FontSize="{StaticResource SettingBtnFontSize}"
                                            Margin="10,0,0,0"
                                            Click="BtnSetPitchHalf_Click"/>
                                </StackPanel>

                                <Label Content="提示：步进变距范围 9.0 ~ 14.0 mm，步长 0.5 mm"
                                       FontSize="12"
                                       Foreground="Gray"
                                       Margin="0,2,0,4"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- ── 右列 ── -->
                    <StackPanel Grid.Column="1" Margin="3,0,0,0">

                        <!-- 吸排液操作 -->
                        <GroupBox BorderThickness="{StaticResource GroupBoxBorderThickness}">
                            <GroupBox.Header>
                                <Label Content="吸排液操作"
                                       FontSize="{StaticResource SettingGroupBoxTitleFontSize}"
                                       Foreground="White"/>
                            </GroupBox.Header>
                            <StackPanel Margin="5,8">
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Label Content="体积 (µL)："
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingTitleWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <Label Content="："
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingColonWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <TextBox x:Name="TxtVolume"
                                             Text="100"
                                             Width="{StaticResource SettingValueWidth}"
                                             Height="30"
                                             FontSize="{StaticResource SettingNormalFontSize}"
                                             VerticalContentAlignment="Center"
                                             Margin="0,0,10,0"/>
                                    <Label Content="µL"
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingUnitWidth}"
                                           VerticalContentAlignment="Center"/>

                                    <Button Content="吸  液"
                                            Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                            Height="30" Width="90"
                                            FontSize="{StaticResource SettingBtnFontSize}"
                                            Margin="5,0"
                                            Click="BtnAspirate_Click"/>
                                    <Button Content="排  液"
                                            Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                            Height="30" Width="90"
                                            FontSize="{StaticResource SettingBtnFontSize}"
                                            Margin="5,0"
                                            Click="BtnDispense_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- 吸排液速度 -->
                        <GroupBox BorderThickness="{StaticResource GroupBoxBorderThickness}" Margin="0,5,0,0">
                            <GroupBox.Header>
                                <Label Content="吸排液速度"
                                       FontSize="{StaticResource SettingGroupBoxTitleFontSize}"
                                       Foreground="White"/>
                            </GroupBox.Header>
                            <StackPanel Margin="5,8">
                                <!-- 吸液速度 -->
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Label Content="吸液速度："
             FontSize="{StaticResource SettingNormalFontSize}"
             Width="{StaticResource SettingTitleWidth}"
             VerticalContentAlignment="Center"/>
                                    <Label Content="："
             FontSize="{StaticResource SettingNormalFontSize}"
             Width="{StaticResource SettingColonWidth}"
             VerticalContentAlignment="Center"/>
                                    <ComboBox x:Name="CmbAspSpeed"
                Width="100" Height="30"
                FontSize="{StaticResource SettingNormalFontSize}"
                VerticalContentAlignment="Center"
                SelectedIndex="2">
                                        <ComboBoxItem Content="慢 (01)"/>
                                        <ComboBoxItem Content="中 (02)"/>
                                        <ComboBoxItem Content="快 (03)"/>
                                        <ComboBoxItem Content="最快 (04)"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- 排液速度 -->
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Label Content="排液速度："
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingTitleWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <Label Content="："
                                           FontSize="{StaticResource SettingNormalFontSize}"
                                           Width="{StaticResource SettingColonWidth}"
                                           VerticalContentAlignment="Center"/>
                                    <ComboBox x:Name="CmbDisSpeed"
                                          Width="100" Height="30"
                                          FontSize="{StaticResource SettingNormalFontSize}"
                                          VerticalContentAlignment="Center"
                                          SelectedIndex="1">
                                        <ComboBoxItem Content="慢 (01)"/>
                                        <ComboBoxItem Content="中 (02)"/>
                                        <ComboBoxItem Content="快 (03)"/>
                                        <ComboBoxItem Content="最快 (04)"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="设置速度"
                                            Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                            Height="30" Width="90"
                                            FontSize="{StaticResource SettingBtnFontSize}"
                                            Margin="5,0"
                                            Click="BtnSetSpeed_Click"/>
                                    <Button Content="读取速度"
                                            Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                            Height="30" Width="90"
                                            FontSize="{StaticResource SettingBtnFontSize}"
                                            Margin="5,0"
                                            Click="BtnReadSpeed_Click"/>
                                </StackPanel>

                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </Grid>

                <!-- ═══ 分隔线 ═══ -->
                <Rectangle Fill="LightGray" VerticalAlignment="Top" Height="2" Margin="0,10,0,0"/>

                <!-- ═══ 通信日志 ═══ -->
                <GroupBox BorderThickness="{StaticResource GroupBoxBorderThickness}" Margin="0,5,0,0">
                    <GroupBox.Header>
                        <Label Content="通信日志"
                               FontSize="{StaticResource SettingGroupBoxTitleFontSize}"
                               Foreground="White"/>
                    </GroupBox.Header>
                    <StackPanel Margin="5,8">
                        <ScrollViewer x:Name="LogScroll"
                                      Height="150"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtLog"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="NoWrap"
                                       Margin="4"/>
                        </ScrollViewer>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <Button Content="清空日志"
                                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                    Height="30" Width="90"
                                    FontSize="{StaticResource SettingBtnFontSize}"
                                    Margin="5,0"
                                    Click="BtnClearLog_Click"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</metro:MetroWindow>