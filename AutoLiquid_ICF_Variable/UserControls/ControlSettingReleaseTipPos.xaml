<UserControl x:Class="AutoLiquid_ICF_Variable.UserControls.ControlSettingReleaseTipPos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Background="White">
    <UserControl.Resources>
        <Thickness x:Key="RowMarginTop">0,5,0,0</Thickness>
    </UserControl.Resources>

    <Grid x:Name="GridReleaseTipPos">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <!--标题-->
        <Grid Grid.Row="0" Grid.Column="0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <CheckBox x:Name="CheckBoxReleaseTipPos" HorizontalAlignment="Center" Padding="0"/>
                <Label HorizontalContentAlignment="Center" Content="{StaticResource Position}" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold"/>
                <Label x:Name="LabelPos" HorizontalContentAlignment="Center" Content="1" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold" Margin="-8,0,0,0"/>
            </StackPanel>
        </Grid>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2">
            <Label  Width="{StaticResource BtnTrimmingWidth}"/>
            <Label  Width="{StaticResource SettingHoleValueWidth}" HorizontalContentAlignment="Center" Content="{StaticResource ValueX}" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="4">
            <Label  Width="{StaticResource BtnTrimmingWidth}"/>
            <Label  Width="{StaticResource SettingHoleValueWidth}" HorizontalContentAlignment="Center" Content="{StaticResource ValueY}" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="6">
            <Label  Width="{StaticResource BtnTrimmingWidth}"/>
            <Label  Width="{StaticResource SettingHoleValueWidth}" HorizontalContentAlignment="Center" Content="{StaticResource ValueZ}" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold"/>
        </StackPanel>
        <!--预退枪头位置-->
        <Label Grid.Row="1" Grid.Column="0" HorizontalContentAlignment="Center" Content="{StaticResource PrepareReleaseTipPos}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
        <Label Grid.Row="1" Grid.Column="1" Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
        <local:ControlSettingPos Grid.Row="1" Grid.Column="2" x:Name="ControlPrepareReleaseTipPosX"/>
        <Label Grid.Row="1" Grid.Column="3" HorizontalContentAlignment="Center" Content="," Width="{StaticResource SettingColonWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
        <local:ControlSettingPos Grid.Row="1" Grid.Column="4" x:Name="ControlPrepareReleaseTipPosY"/>
        <Label Grid.Row="1" Grid.Column="5" HorizontalContentAlignment="Center" Content="," Width="{StaticResource SettingColonWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
        <local:ControlSettingPos Grid.Row="1" Grid.Column="6" x:Name="ControlPrepareReleaseTipPosZ"/>

        <!--退枪头位置-->
        <Label Grid.Row="2" Grid.Column="0" HorizontalContentAlignment="Center" Content="{StaticResource ReleaseTipPos}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="{StaticResource RowMarginTop}"/>
        <Label Grid.Row="2" Grid.Column="1" Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="{StaticResource RowMarginTop}"/>
        <local:ControlSettingPos Grid.Row="2" Grid.Column="2" x:Name="ControlReleaseTipPosX" Margin="{StaticResource RowMarginTop}"/>
        <Label Grid.Row="2" Grid.Column="3" HorizontalContentAlignment="Center" Content="," Width="{StaticResource SettingColonWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="{StaticResource RowMarginTop}"/>
        <local:ControlSettingPos Grid.Row="2" Grid.Column="4" x:Name="ControlReleaseTipPosY" Margin="{StaticResource RowMarginTop}"/>
        <Label Grid.Row="2" Grid.Column="5" HorizontalContentAlignment="Center" Content="," Width="{StaticResource SettingColonWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
        <local:ControlSettingPos Grid.Row="2" Grid.Column="6" x:Name="ControlReleaseTipPosZ" Margin="{StaticResource RowMarginTop}"/>
    </Grid>
</UserControl>
