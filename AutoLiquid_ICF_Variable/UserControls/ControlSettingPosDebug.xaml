<UserControl x:Class="AutoLiquid_ICF_Variable.UserControls.ControlSettingPosDebug"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             Background="White">

    <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,0,0">
            <Label Width="{StaticResource SettingTitleWidth}" HorizontalContentAlignment="Center" Content="{StaticResource DebugMode}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
            <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
            <RadioButton x:Name="RBtnDebugThin" GroupName="DebugMode" Content="{StaticResource DebugThin}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
            <RadioButton x:Name="RBtnDebugThick" GroupName="DebugMode" Content="{StaticResource DebugThick}" FontSize="{StaticResource MahApps.Font.Size.Default}" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
