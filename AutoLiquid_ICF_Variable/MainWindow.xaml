<metro:MetroWindow x:Class="AutoLiquid_ICF_Variable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoLiquid_ICF_Variable"
        xmlns:metro="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:userControls="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
        mc:Ignorable="d"
        x:Name="mainWindow"
        d:DesignWidth="1080"
        Title="{StaticResource AppName}" WindowState="Maximized"  WindowStartupLocation="CenterScreen" GlowBrush="{DynamicResource MahApps.Brushes.Accent}">

    <Grid>
        <!--内容写在下面-->
        <Grid Margin="10,5,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.25*"/>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.25*"/>
                </Grid.ColumnDefinitions>
                <!--菜单栏-->
                <Menu x:Name="MenuBar">
                    <MenuItem x:Name="MenuItemUserSettingHead1" Header="{StaticResource HeadSetting}"/>
                    <MenuItem x:Name="MenuItemVariablePitchDebug" Header="{StaticResource VariablePitchDebug}"/>
                    <MenuItem Header="{StaticResource HeadSetting}" Visibility="Collapsed">
                        <MenuItem Header="{StaticResource Head1}" Visibility="Collapsed"/>
                        <MenuItem x:Name="MenuItemUserSettingHead2" Header="{StaticResource Head2}"/>
                        <MenuItem x:Name="MenuItemOriginCalibration" Header="{StaticResource OriginCalibration}" Visibility="Collapsed"/>
                    </MenuItem>
                    <MenuItem x:Name="MenuItemTask" Header="{StaticResource Task}">
                    </MenuItem>
                    <MenuItem x:Name="MenuItemPermission" Header="{StaticResource Permission}">
                        <MenuItem x:Name="MenuItemModifyPwd" Header="{StaticResource ModifyPwd}"/>
                    </MenuItem>
                    <MenuItem x:Name="MenuItemHelp" Header="{StaticResource Help}">
                        <MenuItem x:Name="MenuItemAbout" Header="{StaticResource About}"/>
                    </MenuItem>
                </Menu>

                <!--进度条-->
                <userControls:ControlProgressBar x:Name="ControlProgressBar" Grid.Column="1" Margin="20,0,20,0"/>
            </Grid>

            <!--动态盘位分布-->
            <Grid Grid.Row="1">
                <!--只显示盘符的盘位-->
                <Grid x:Name="GridTemplateContainerOnlyNumber" >

                </Grid>
                <!--真正填充耗材的盘位-->
                <Grid x:Name="GridTemplateContainer">

                </Grid>
            </Grid>
         

            <StackPanel  x:Name="BottomBar" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0">
                <CheckBox x:Name="CheckBoxReplaceTipOverRange" Content="{StaticResource ReplaceTipOverRange}" FontSize="20" FontWeight="Bold"/>
                <!--风扇默认关闭-->
                <Button x:Name="BtnFan" Content="{StaticResource FanOpen}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="70" Height="40" FontSize="20" Margin="10,0,0,0"/>
                <!--照明默认打开-->
                <Button x:Name="BtnLight" Content="{StaticResource LightClose}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="90" Height="40" FontSize="20" Margin="10,0,0,0"/>
                <Button x:Name="BtnUV" Content="{StaticResource UVOpen}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="90" Height="40" FontSize="20" Margin="10,0,0,0"/>
                <Button x:Name="BtnImportData" Content="{StaticResource Import}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="70" Height="40" FontSize="20" Margin="10,0,0,0"/>
                <Button x:Name="BtnReset" Content="{StaticResource Reset}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="70" Height="40" FontSize="20" Margin="10,0,0,0"/>
                <Button x:Name="BtnLaunchPlate" Content="{StaticResource LaunchPlate}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="90" Height="40" FontSize="20" Margin="10,0,0,0"/>
                <Button x:Name="BtnRun"  Content="{StaticResource Run}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="70" Height="40" FontSize="20" Margin="20,0,0,0"/>
            </StackPanel>
        </Grid>

        <!--运行弹出框-->
        <DockPanel x:Name="LayoutRunningLoading" Width="300" Background="Transparent" VerticalAlignment="Center" Visibility="Hidden">
            <DockPanel.RenderTransform>
                <TranslateTransform x:Name="LayoutLoadingRenderTransform"/>
            </DockPanel.RenderTransform>
            <Border CornerRadius="10" Background="White" BorderBrush="{DynamicResource MahApps.Brushes.Accent}" BorderThickness="5">
                <StackPanel VerticalAlignment="Top">
                    <StackPanel  Margin="0,30">
                        <metro:ProgressRing x:Name="ProgressRingLoading" Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                        <Label x:Name="LabelPrompt" Content="{StaticResource Prompt_Running_Pls_Wait}" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel x:Name="StackPanelIntervalRemain" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,-20">
                        <Label x:Name="LabelIntervalRemainTitle" Content="{StaticResource IntervalRemain}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Label x:Name="LabelIntervalRemain" Content="" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40" Foreground="Red" FontWeight="Bold"/>
                            <Label Content="{StaticResource Second}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>

                    <DockPanel x:Name="DockPanelAllBtn" Margin="10,30,15,10">
                        <Button DockPanel.Dock="Right" x:Name="BtnPause" Content="{StaticResource Pause}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="60"/>
                        <StackPanel x:Name="StackPanelStopOrContinue" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnStop"  Content="{StaticResource Stop}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="60" Margin="5,0,0,0"/>
                            <Button x:Name="BtnContinue"  Content="{StaticResource Continue}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="60" Margin="5,0,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>
        </DockPanel>

        <!--导入中弹出框-->
        <DockPanel x:Name="LayoutImportLoading" Width="300" Background="Transparent" VerticalAlignment="Center" Visibility="Collapsed">
            <Border CornerRadius="10" Background="White" BorderBrush="{DynamicResource MahApps.Brushes.Accent}" BorderThickness="5">
                <StackPanel VerticalAlignment="Top" Margin="0,30">
                    <metro:ProgressRing Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                    <Label Content="{StaticResource Prompt_Importing_Pls_Wait}" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </DockPanel>
    </Grid>
</metro:MetroWindow>
