<metro:MetroWindow x:Class="AutoLiquid_ICF_Variable.Window.WindowPwdModify"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:metro="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="{StaticResource PwdInput}" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" GlowBrush="{DynamicResource MahApps.Brushes.Accent}">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,20,20,0">
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="{DynamicResource PasswordOld}" Grid.Row="0" Grid.Column="0" VerticalContentAlignment="Center" FontSize="20"/>
                <Label Content=":" Grid.Row="0" Grid.Column="1" VerticalContentAlignment="Center" FontSize="20"/>
                <PasswordBox x:Name="PasswordBoxOld" Grid.Row="0"  Grid.Column="2" Width="160" FontSize="20" VerticalContentAlignment="Center"/>

                <Label Content="{DynamicResource PasswordNew}" Grid.Row="1" Grid.Column="0" VerticalContentAlignment="Center" FontSize="20" Margin="0,5,0,0"/>
                <Label Content=":" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center" FontSize="20" Margin="0,5,0,0"/>
                <PasswordBox x:Name="PasswordBoxNew" Grid.Row="1" Grid.Column="2" Width="160" FontSize="20" VerticalContentAlignment="Center" Margin="0,5,0,0"/>

                <Label Content="{DynamicResource PasswordConfirm}" Grid.Row="2" Grid.Column="0" VerticalContentAlignment="Center" FontSize="20" Margin="0,5,0,0"/>
                <Label Content=":" Grid.Row="2" Grid.Column="1" VerticalContentAlignment="Center" FontSize="20" Margin="0,5,0,0"/>
                <PasswordBox x:Name="PasswordBoxConfirm" Grid.Row="2" Grid.Column="2" Width="160" FontSize="20" VerticalContentAlignment="Center" Margin="0,5,0,0"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Name="BtnCancel" Content="{StaticResource Cancel}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="70" Height="40" FontSize="20" Margin="10"/>
                <Button Name="BtnConfirm" Content="{StaticResource Confirm}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="70" Height="40" FontSize="20" Margin="10"/>
            </StackPanel>

            <Label x:Name="LabelError"  FontSize="16" Content="" HorizontalContentAlignment="Center" Foreground="Red"/>
        </StackPanel>
    </Grid>
</metro:MetroWindow>
