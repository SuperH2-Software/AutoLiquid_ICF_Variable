<UserControl x:Class="AutoLiquid_ICF_Variable.UserControls.ControlSettingLaunchPlate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             Background="White">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
                <Label Width="{StaticResource SettingTitleWidth}" HorizontalContentAlignment="Center" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold"/>
                <Label Width="{StaticResource SettingColonWidth}"/>
                <Label Width="{StaticResource BtnTrimmingWidth}"/>
                <Label Width="{StaticResource SettingHoleValueWidth}" HorizontalContentAlignment="Center" Content="{StaticResource ValueY}" FontSize="{StaticResource SettingTitleFontSize}" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label HorizontalContentAlignment="Center" Content="{StaticResource LaunchPlate}" Width="{StaticResource SettingTitleWidth}" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                <Label Width="{StaticResource SettingColonWidth}" Content=":" FontSize="{StaticResource MahApps.Font.Size.Default}"/>
                <local:ControlSettingPos x:Name="ControlLaunchPlateY"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
