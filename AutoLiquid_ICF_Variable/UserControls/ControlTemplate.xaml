<UserControl x:Class="AutoLiquid_ICF_Variable.UserControls.ControlTemplate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoLiquid_ICF_Variable.UserControls"
             mc:Ignorable="d" >
    <Grid>
        <Border BorderBrush="{StaticResource TemplateBorderColor}" BorderThickness="{StaticResource TemplateBorderThickness}">
            <Grid x:Name="Template" x:FieldModifier="public">
            </Grid>
        </Border>
    </Grid>
</UserControl>
