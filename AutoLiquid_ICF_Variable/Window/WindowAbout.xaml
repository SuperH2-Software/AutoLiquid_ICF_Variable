<metro:MetroWindow  x:Class="AutoLiquid_ICF_Variable.Window.WindowAbout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:metro="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="{StaticResource About}" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" GlowBrush="{DynamicResource MahApps.Brushes.Accent}">
    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,20,10,0">
                <Image x:Name="ImageLogo" Height="60"  Margin="0,10,0,0" VerticalAlignment="Top"/>

                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Label x:Name="LabelSoftwareName" Content="{StaticResource AppName}" FontWeight="ExtraBold" FontSize="15"/>
                        <Label Content="版本"  FontWeight="ExtraBold" FontSize="15" Margin="5,0,0,0"/>
                        <Label x:Name="LabelVersion"  FontWeight="ExtraBold" FontSize="15"/>
                    </StackPanel>

                    <TextBlock x:Name="TextBlockAboutInfo" Text="{StaticResource Copyright}" Margin="5,0,0,0" LineHeight="20" LineStackingStrategy="BlockLineHeight"/>
                </StackPanel>
            </StackPanel>

            <!--软件更新日志-->
            <StackPanel Orientation="Vertical" Margin="10,10,10,0">
                <Label Content="{StaticResource UpdateLog}" FontSize="18"/>
                <TextBox x:Name="TextBoxUpdateLog" MaxHeight="400" IsReadOnly="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="BtnCheck4Update" Content="{StaticResource Check4Update}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="60" Height="30" Margin="10"/>
                <Button Name="BtnConfirm" Content="{StaticResource Confirm}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="60" Height="30" Margin="10" HorizontalAlignment="Right"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</metro:MetroWindow>
